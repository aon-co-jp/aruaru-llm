<?xml version="1.0" encoding="utf-8"?>
<!-- タブレット向け(幅600dp以上): 720dp上限+中央寄せ(open-web-server
     Android版のタブレット対応方針を踏襲)。 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:maxWidth="720dp"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/server_url_label"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/serverUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints="url"
            android:hint="http://10.0.2.2:8080"
            android:inputType="textUri"
            android:text="http://10.0.2.2:8080" />

        <Button
            android:id="@+id/changeProfileButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/change_profile_button" />

        <TextView
            android:id="@+id/chatLog"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:scrollbars="vertical"
            android:textIsSelectable="true"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/messageInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/message_hint"
                android:inputType="text" />

            <Button
                android:id="@+id/sendButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/send_button" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
